#functions da FILA
fila_dados  = []   # armazena as ocorrências na ordem de entrada
fila_inicio = 0    # aponta para o próximo a ser atendido

def fila_enqueue(ocorrencia):
    fila_dados.append(ocorrencia)

def fila_dequeue():
    global fila_inicio
    if fila_inicio >= len(fila_dados):
        return None
    item = fila_dados[fila_inicio]
    fila_inicio += 1
    return item

def fila_vazia():
    return fila_inicio >= len(fila_dados)


#functions da pilha
pilha_historico = [] #registrar histórico de ações

def pilha_push(acao):
    pilha_historico.append(acao)

def pilha_pop():
    if not pilha_historico:
        return None
    return pilha_historico.pop()

def pilha_topo():
    if not pilha_historico:
        return None
    return pilha_historico[-1]

# arvore
raizArvore = None

class No:
    def __init__(self, id, ocorrencia):
        self.id = id
        self.ocorrencia = ocorrencia
        self.esquerda = None
        self.direita = None


def inserir(raiz, ocorrencia):

    if raiz is None:
        return No(ocorrencia["id"], ocorrencia)

    if ocorrencia["id"] < raiz.id:
        raiz.esquerda = inserir(raiz.esquerda, ocorrencia)

    elif ocorrencia["id"] > raiz.id:
        raiz.direita = inserir(raiz.direita, ocorrencia)

    return raiz


def buscar_id(raiz, id_oc):
    if raiz is None:
        return None

    if id_oc == raiz.id:
        return raiz.ocorrencia

    elif id_oc < raiz.id:
        return buscar_id(raiz.esquerda, id_oc)

    else:
        return buscar_id(raiz.direita, id_oc)


def printa_arvore(raiz):

    if raiz is not None:
        printa_arvore(raiz.esquerda)
        print(raiz.id)
        printa_arvore(raiz.direita)

#HASH TABLE
hash_por_nome = {}   # chave: nome em minúsculo
hash_por_tipo = {}   # chave: tipo em minúsculo

#Busca rápida por nome do solicitante ou tipo
#Colisão -> resolvida por encadeamento
def hash_inserir(ocorrencia):
    chave_nome = ocorrencia["nome"].lower()
    chave_tipo = ocorrencia["tipo"].lower()

    # encadeamento: se a chave já existe, apenas adiciona à lista
    if chave_nome not in hash_por_nome:
        hash_por_nome[chave_nome] = []
    hash_por_nome[chave_nome].append(ocorrencia)

    if chave_tipo not in hash_por_tipo:
        hash_por_tipo[chave_tipo] = []
    hash_por_tipo[chave_tipo].append(ocorrencia)

def hash_buscar_nome(nome):
    return hash_por_nome.get(nome.lower(), [])

def hash_buscar_tipo(tipo):
    return hash_por_tipo.get(tipo.lower(), [])

