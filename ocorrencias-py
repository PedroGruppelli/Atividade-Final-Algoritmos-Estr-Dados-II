#REQ 1 Cadastrar ocorrência
def cadastrar_ocorrencia():
    global contador_chegada
    print("\n CADASTRAR OCORRÊNCIA ")

    nome      = input("Nome do solicitante : ")
#    id_oc     = gerar_id(nome)
    id_oc = gerar_id()
    tipo      = input("Tipo da ocorrência  : ")
    descricao = input("Descrição           : ")

    while True:
        prioridade = input("Prioridade (1 a 5)  : ")
        if prioridade in ["1", "2", "3", "4", "5"]:
            break
        print("  ! Digite um número entre 1 e 5.")

    contador_chegada += 1

    ocorrencia = {
        "id"       : id_oc,
        "nome"     : nome,
        "tipo"     : tipo,
        "descricao": descricao,
        "prioridade": int(prioridade),
        "chegada"  : contador_chegada,
        "status"   : "Aberto"
    }

    #insere na LISTA GERAL
    lista_ocorrencias.append(ocorrencia)

    #insere na FILA de chegada
    fila_enqueue(ocorrencia)

    #insere na HASH
    hash_inserir(ocorrencia)

    #registrA na PILHA de historico
    pilha_push(f"Cadastro da ocorrência {id_oc} ({nome})")

    #insere na arvore
    global raizArvore
    raizArvore = inserir(raizArvore, ocorrencia)
    print("arvore")
    printa_arvore(raizArvore)

    print(f"\n✓ Ocorrência cadastrada com ID: {id_oc}")

