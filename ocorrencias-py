def ordenacao(lista, campo):
    nova_lista = lista.copy()
    quicksort(nova_lista, 0, len(nova_lista)-1, campo)
    return nova_lista


def quicksort(lista, inicio, fim, campo):

    if inicio < fim:

        pivo = particionar(lista, inicio, fim, campo)

        quicksort(lista, inicio, pivo-1, campo)

        quicksort(lista, pivo+1, fim, campo)


def particionar(lista, inicio, fim, campo):

    pivo = lista[fim]

    i = inicio - 1

    for j in range(inicio, fim):

        if lista[j][campo] >= pivo[campo]:

            i += 1
            lista[i], lista[j] = lista[j], lista[i]

    lista[i+1], lista[fim] = lista[fim], lista[i+1]

    return i+1


