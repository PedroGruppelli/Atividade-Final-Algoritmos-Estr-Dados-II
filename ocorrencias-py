#REQ 3 Atender pela ordem de chegada
def atender_fila():
    print("\n ATENDER PELA ORDEM DE CHEGADA")
    if fila_vazia():
        print("\n Nenhuma ocorrência aguardando na fila.")
        return

    ocorrencia = fila_dequeue()
    ocorrencia["status"] = "Atendido"

    print("  Atendendo a ocorrência mais antiga:")
    exibir_ocorrencia(ocorrencia)

    # registra na pilha
    pilha_push(f"Atendimento (fila) da ocorrência {ocorrencia['id']} ({ocorrencia['nome']})")



